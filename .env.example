# ─── Admin seed credentials ────────────────────────────────────────────────────
# Used ONLY on the very first boot to create the admin account.
# Changing these after the DB is seeded has no effect — update via the app instead.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ─── Dummy hash (login timing protection) ──────────────────────────────────────
# Prevents username enumeration by ensuring failed lookups take the same time as
# real password comparisons. If left empty, a fresh hash is auto-generated on
# each server start (safe, but slightly slower on cold boot).
#
# To pre-compute a stable value, run:
#   node -e "const {scryptSync,randomBytes}=require('crypto'); \
#     const s=randomBytes(16).toString('hex'); \
#     console.log(s+':'+scryptSync('dummy',s,64).toString('hex'))"
#
DUMMY_HASH=
